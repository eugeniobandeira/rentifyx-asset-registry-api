{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000" ]
  },
  "OpenApi": {
    "ContactName": "eugeniobandeira",
    "ContactUrl": "https://github.com/eugeniobandeira"
  },
  "RateLimit": {
    "PermitLimit": 100,
    "WindowSeconds": 60,
    "QueueLimit": 0
  },
  "RequestSizeLimit": {
    "MaxBytes": 1048576
  },
  "OpenTelemetry": {
    "OTEL_EXPORTER_OTLP_ENDPOINT": "",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "http/protobuf",
    "OTEL_EXPORTER_OTLP_HEADERS": "",
    "OTEL_SERVICE_NAME": "RentifyxAssetRegistry.Api",
    "OTEL_RESOURCE_ATTRIBUTES": "deployment.environment=production"
  },
  "AWS": {
    "Region": "sa-east-1",
    "SecretsManager": {
      "SecretName": "rentifyx/asset-registry/{environment}"
    }
  },
  "Jwt": {
    "Issuer": "rentifyx-identity",
    "Audience": "rentifyx-services"
  }
}
